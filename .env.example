# ============================================================================
# VRP Solver Configuration
# ============================================================================
# Chỉnh sửa giá trị và rename thành .env
# ⚠️ KHÔNG commit .env file lên Git
# ============================================================================

# ============================================================================
# API Settings
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True
API_TITLE=VRP Solver API
API_VERSION=0.1.0

# ============================================================================
# Database Configuration
# ============================================================================
# Tùy chọn 1: SQLite (Local development - Khuyến nghị)
DATABASE_URL=sqlite:///./vrp.db

# Tùy chọn 2: PostgreSQL (Production)
# DATABASE_URL=postgresql://user:password@localhost:5432/vrp_db
# DB_ECHO=False

# ============================================================================
# Redis Cache (Optional)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=3600

# ============================================================================
# JWT & Security
# ============================================================================
# Tạo secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-this-to-your-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# Google Maps API
# ============================================================================
# Lấy từ: https://console.cloud.google.com/
# Cần enable: Maps API, Distance Matrix API, Directions API
GOOGLE_MAPS_API_KEY=your_api_key_here
GOOGLE_MAPS_API_TIMEOUT=10

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_FILE=logs/vrp.log

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=development
# development | staging | production

# ============================================================================
# Optimization Configuration
# ============================================================================
# Nearest Neighbor & Genetic Algorithm settings

# Genetic Algorithm
GA_POPULATION_SIZE=100
GA_GENERATIONS=500
GA_MUTATION_RATE=0.1
GA_CROSSOVER_RATE=0.8
GA_ELITE_SIZE=5
GA_EARLY_STOPPING_PATIENCE=20

# Distance Calculation
# euclidean | haversine | google_maps
DISTANCE_CALCULATION_METHOD=euclidean

# ============================================================================
# Features
# ============================================================================
ENABLE_GOOGLE_MAPS=False
ENABLE_CACHING=True
ENABLE_CORS=True
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8501"]

# ============================================================================
# Email Configuration (Optional - for notifications)
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@vrpsolver.app

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ============================================================================
# Pagination
# ============================================================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================================================
# File Upload (Optional)
# ============================================================================
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=uploads/

# ============================================================================
# External Services
# ============================================================================
# Timeout cho các API calls (seconds)
API_TIMEOUT=30
MAPS_API_TIMEOUT=60

# ============================================================================
# Development Tools
# ============================================================================
ENABLE_SWAGGER=True
ENABLE_REDOC=True
ENABLE_API_DOCS=True
